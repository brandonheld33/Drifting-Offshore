<div class="cart-page">

  <h1 class="cart-page__title">Your Cart</h1>

  {%- if cart.item_count > 0 -%}

    {%- for item in cart.items -%}
      <div class="cart-item">

        <a href="{{ item.url }}">
          {%- if item.image != blank -%}
            <img
              src="{{ item.image | img_url: '200x' }}"
              alt="{{ item.title | escape }}"
              class="cart-item__image"
            >
          {%- else -%}
            <div class="cart-item__image"></div>
          {%- endif -%}
        </a>

        <div>
          <div class="cart-item__name">{{ item.product.title }}</div>
          {%- unless item.variant.title == 'Default Title' -%}
            <div class="cart-item__variant">{{ item.variant.title }}</div>
          {%- endunless -%}
          <div class="cart-item__price">{{ item.final_line_price | money }}</div>
          <a
            href="/cart/change?line={{ forloop.index }}&quantity=0"
            class="cart-item__remove"
          >Remove</a>
        </div>

      </div>
    {%- endfor -%}

    <div class="cart-page__footer">
      <div class="cart-page__subtotal">Subtotal: {{ cart.total_price | money }}</div>
      <a href="/checkout" class="cart-page__checkout">Checkout</a>
    </div>

  {%- else -%}

    <div class="cart-page__empty">
      <p>Your cart is empty.</p>
      <a href="/" class="cart-page__continue">Continue Shopping</a>
    </div>

  {%- endif -%}

</div>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
