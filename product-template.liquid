<div class="product-page">

  <div class="product-page__gallery">
    {%- if product.featured_image != blank -%}
      <img
        src="{{ product.featured_image | img_url: '800x' }}"
        alt="{{ product.title | escape }}"
        class="product-page__main-image"
      >
    {%- else -%}
      <div class="product-page__image-placeholder">No image yet</div>
    {%- endif -%}
  </div>

  <div class="product-page__info">

    {%- if product.vendor != blank -%}
      <p class="product-page__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h1 class="product-page__title">{{ product.title }}</h1>

    <div class="product-page__price">
      {{ product.price | money }}
    </div>

    <form action="/cart/add" method="post" class="product-form">

      {%- if product.variants.size > 1 -%}
        <label class="product-page__label" for="variant-select">Size</label>
        <select name="id" id="variant-select" class="product-page__select">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% unless variant.available %}disabled{% endunless %}
            >
              {{ variant.title }}{% unless variant.available %} — Sold Out{% endunless %}
            </option>
          {%- endfor -%}
        </select>
      {%- else -%}
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      {%- endif -%}

      {%- if product.description != blank -%}
        <div class="product-page__description">{{ product.description }}</div>
      {%- endif -%}

      <button
        type="submit"
        class="product-page__add-btn"
        {% unless product.available %}disabled{% endunless %}
      >
        {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>

    </form>

  </div>

</div>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
