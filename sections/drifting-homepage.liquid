<div class="do-homepage">

  <!-- HERO SLIDESHOW -->
  <div class="do-hero" id="doHero">
    <div class="do-hero__slide active" style="background-image: url('https://images.unsplash.com/photo-1502680390469-be75c86b636f?w=1600&q=80')"></div>
    <div class="do-hero__slide" style="background-image: url('https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=1600&q=80')"></div>
    <div class="do-hero__slide" style="background-image: url('https://images.unsplash.com/photo-1531722569936-825d4ebd0b79?w=1600&q=80')"></div>
    <div class="do-hero__overlay">
      <h1 class="do-hero__title">Drifting Offshore</h1>
      <p class="do-hero__tagline">Built for the Salt. Made for the Drift.</p>
    </div>
  </div>

  <!-- PHOTO COLLAGE -->
  <div class="do-collage">
    <div class="do-collage__item" style="background-image: url('https://images.unsplash.com/photo-1530053969600-caed2596d242?w=900&q=80')"></div>
    <div class="do-collage__item" style="background-image: url('https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=600&q=80')"></div>
    <div class="do-collage__item" style="background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=600&q=80')"></div>
    <div class="do-collage__item" style="background-image: url('https://images.unsplash.com/photo-1519046904884-53103b34b206?w=600&q=80')"></div>
    <div class="do-collage__item" style="background-image: url('https://images.unsplash.com/photo-1437622368342-7a3d73a34c8f?w=600&q=80')"></div>
  </div>

  <!-- PRODUCTS -->
  <div class="do-products">
    <h2 class="do-products__heading">Shop the Collection</h2>
    <div class="do-products__grid">

      <a href="/products/the-surfer-tee" class="do-product-card">
        <div class="do-product-card__image">
          {%- assign surfer_tee = all_products['the-surfer-tee'] -%}
          {%- if surfer_tee.featured_image != blank -%}
            <img src="{{ surfer_tee.featured_image | img_url: '600x' }}" alt="The Surfer Tee" style="width:100%;height:100%;object-fit:cover;">
          {%- else -%}
            <span class="do-product-card__placeholder">The Surfer Tee</span>
          {%- endif -%}
        </div>
        <div class="do-product-card__body">
          <div class="do-product-card__name">The Surfer Tee</div>
          <div class="do-product-card__price">
            {%- if surfer_tee.price != blank -%}{{ surfer_tee.price | money }}{%- else -%}Shop Now{%- endif -%}
          </div>
          <span class="do-product-card__btn">Shop Now</span>
        </div>
      </a>

      <a href="/products/the-fishing-tee" class="do-product-card">
        <div class="do-product-card__image">
          {%- assign fishing_tee = all_products['the-fishing-tee'] -%}
          {%- if fishing_tee.featured_image != blank -%}
            <img src="{{ fishing_tee.featured_image | img_url: '600x' }}" alt="The Fishing Tee" style="width:100%;height:100%;object-fit:cover;">
          {%- else -%}
            <span class="do-product-card__placeholder">The Fishing Tee</span>
          {%- endif -%}
        </div>
        <div class="do-product-card__body">
          <div class="do-product-card__name">The Fishing Tee</div>
          <div class="do-product-card__price">
            {%- if fishing_tee.price != blank -%}{{ fishing_tee.price | money }}{%- else -%}Shop Now{%- endif -%}
          </div>
          <span class="do-product-card__btn">Shop Now</span>
        </div>
      </a>

    </div>
  </div>

  <!-- BRAND STATEMENT -->
  <div class="do-brand">
    <div class="do-brand__divider"></div>
    <p class="do-brand__text">
      Born from early mornings on the water and late evenings at the lineup.
      Drifting Offshore is coastal apparel for those who live between the waves and the tide.
    </p>
  </div>

</div>

<script>
  const slides = document.querySelectorAll('#doHero .do-hero__slide');
  let current = 0;
  setInterval(() => {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
  }, 4500);
</script>

{% schema %}
{
  "name": "Drifting Homepage",
  "settings": []
}
{% endschema %}
